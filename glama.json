{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": [
    "useallowance"
  ],
  "name": "allowance-mcp",
  "description": "Payment security for AI agents. Allowance lets agents request scoped human approval, receive limited virtual cards, complete checkout, and report receipts without exposing the human's real card.",
  "homepage": "https://useallowance.com/mcp",
  "repository": "https://github.com/useallowance/allowance-mcp-public",
  "icon": "https://raw.githubusercontent.com/useallowance/allowance-mcp-public/main/assets/allowance-logo-green-bg.jpg",
  "image": "https://raw.githubusercontent.com/useallowance/allowance-mcp-public/main/assets/social-card.png",
  "type": "mcp_server",
  "status": "stable",
  "framework": "FastMCP",
  "tools": 22,
  "transport": [
    "http"
  ],
  "keywords": [
    "mcp",
    "payments",
    "oauth",
    "agent-purchasing",
    "virtual-cards",
    "checkout",
    "human-in-the-loop",
    "agent-payments",
    "payment-security",
    "receipts",
    "spend-controls"
  ],
  "mcpServers": {
    "allowance": {
      "type": "http",
      "url": "https://mcp.useallowance.com",
      "description": "OAuth-protected remote MCP server for Allowance agent purchasing."
    }
  },
  "features": {
    "agent_purchasing": {
      "enabled": true,
      "capabilities": [
        "human_approval",
        "virtual_cards",
        "receipts",
        "audit_trails"
      ]
    },
    "authentication": {
      "enabled": true,
      "capabilities": [
        "oauth2"
      ]
    }
  }
}
