{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.useallowance/allowance-mcp",
  "title": "Allowance MCP",
  "description": "Payment security for AI agents: request scoped human approval, issue limited virtual cards, complete checkout, and report receipts without exposing the human's real card.",
  "repository": {
    "url": "https://github.com/useallowance/allowance-mcp-public",
    "source": "github"
  },
  "version": "0.1.2",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.useallowance.com",
      "headers": [
        {
          "name": "Authorization",
          "description": "OAuth-issued Allowance bearer token.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
